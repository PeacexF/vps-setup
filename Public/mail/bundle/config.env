# =========================================================
# MAIL SERVER CONFIGURATION
# =========================================================
# This file is sourced by setup modules.
# Keep values shell-compatible.
#
# WARNING:
# This config format is NOT considered stable yet.
# Future modules may introduce new variables.
# =========================================================


# =========================================================
# GENERAL
# =========================================================


# Primary mail domain
DOMAIN="example.com"

# Mail server hostname (FQDN)
HOSTNAME="mail.example.com"

# Server timezone (optional future usage)
TIMEZONE="UTC"


# =========================================================
# NETWORK
# =========================================================

# Force IPv4 only
IPV4_ONLY="true"

# Enable IPv6 later if needed
IPV6_ENABLED="false"


# =========================================================
# TLS / CERTIFICATES
# =========================================================

# TLS mode:
# selfsigned | letsencrypt
TLS_MODE="selfsigned"

# Certificate storage directory
TLS_CERT_DIR="/etc/ssl/mail"

# Self-signed certificate parameters
TLS_COUNTRY="US"
TLS_STATE="New York"
TLS_CITY="New York"
TLS_ORG="MailServer"
TLS_UNIT="IT"


# =========================================================
# POSTFIX
# =========================================================

POSTFIX_INET_PROTOCOLS="ipv4"

# Mailbox format
POSTFIX_MAILBOX_FORMAT="Maildir"

# Message size limit (bytes)
POSTFIX_MESSAGE_SIZE_LIMIT="52428800"

# SMTP banner
POSTFIX_SMTP_BANNER="\$myhostname ESMTP"


# =========================================================
# SUBMISSION / SMTP AUTH
# =========================================================

ENABLE_SUBMISSION="true"

# Force TLS on submission port
SUBMISSION_TLS_ONLY="true"


# =========================================================
# DOVECOT
# =========================================================

# Mail location format
DOVECOT_MAIL_LOCATION="maildir:~/Maildir"

# Authentication mechanisms
DOVECOT_AUTH_MECHANISMS="plain login"

# Require SSL for IMAP auth
DOVECOT_SSL_REQUIRED="true"


# =========================================================
# SECURITY
# =========================================================

# Reject invalid HELO
ENABLE_HELO_CHECKS="true"

# Enable rate limiting
ENABLE_RATE_LIMITS="true"

# Disable plaintext auth without TLS
DISABLE_PLAINTEXT_AUTH="true"

# Minimum TLS protocol
TLS_MIN_VERSION="TLSv1.2"


# =========================================================
# MAILDIR
# =========================================================

# Create Maildir for existing users
MAILDIR_CREATE_EXISTING_USERS="true"

# Create Maildir skeleton for future users
MAILDIR_ENABLE_SKEL="true"


# =========================================================
# LOGGING
# =========================================================

LOG_LEVEL="info"


# =========================================================
# OPTIONAL FUTURE FEATURES
# =========================================================
# These are placeholders for future modules.
# They are intentionally unused for now.
# =========================================================

ENABLE_RSPAMD="false"
ENABLE_OPENDKIM="false"
ENABLE_OPENDMARC="false"
ENABLE_FAIL2BAN_JAILS="false"
ENABLE_POSTSCREEN="false"
ENABLE_POP3="false"
ENABLE_QUOTAS="false"
ENABLE_VIRTUAL_USERS="false"